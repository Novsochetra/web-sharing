{
  "name": "web-local-file-sharing",
  "version": "1.0.0",
  "description": "Local network file sharing between devices",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "build": "pkg server.js -c package.json --output dist/webshare --targets node18-macos-arm64 --compress Brotli",
    "pm2:start": "pm2 start ecosystem.config.js",
    "pm2:stop": "pm2 stop ecosystem.config.js",
    "pm2:restart": "pm2 restart ecosystem.config.js",
    "pm2:logs": "pm2 logs webshare",
    "pm2:status": "pm2 status"
  },
  "pkg": {
    "assets": [
      "public/**/*"
    ]
  },
  "dependencies": {
    "express": "5.2.1",
    "multer": "2.2.0",
    "qrcode": "1.5.4",
    "socket.io": "4.8.3",
    "uuid": "11.1.0"
  },
  "devDependencies": {
    "pkg": "^5.8.1"
  }
}
